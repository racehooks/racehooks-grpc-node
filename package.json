{
  "name": "@racehooks/grpc",
  "version": "0.1.0",
  "description": "RaceHooks gRPC streaming client — low-latency F1 feed delivery over a gRPC server-stream, with automatic reconnect and resume. Node.js only.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/racehooks/racehooks-grpc-node.git"
  },
  "homepage": "https://racehooks.io",
  "bugs": {
    "url": "https://github.com/racehooks/racehooks-grpc-node/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "racehooks",
    "f1",
    "formula1",
    "grpc",
    "streaming",
    "live-timing",
    "realtime",
    "motorsport"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.1",
    "@grpc/proto-loader": "^0.7.10"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.41",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
